<div class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Mes envies de voyage</h1>
    <%= link_to "Nouvelle envie", new_trip_path, class: "btn btn-primary" %>
  </div>

  <div class="row">
    <% @trips.each do |trip| %>
      <div class="col-md-4 mb-4">
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title"><%= trip.name %></h5>
            <h6 class="card-subtitle mb-2 text-muted"><%= trip.destination %></h6>
            <p class="card-text">
              <strong>Voyageurs :</strong> <%= trip.nombre_des_voyageurs %>
            </p>
            <%= link_to "Détails", trip_path(trip), class: "btn btn-primary" %>
            <%= link_to "Supprimer", trip_path(trip), data: { turbo_method: :delete, turbo_confirm: "Êtes-vous sûr ?" }, class: "btn btn-danger" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
