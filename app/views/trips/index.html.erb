<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Mes envies de voyage</h1>
    <%= link_to "Nouvelle envie", new_trip_path, class: "btn btn-primary" %>
  </div>

  <% if @trips.present? %>
    <div class="row">
      <% @trips.each do |trip| %>
        <div class="col-md-4 mb-3">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <h5 class="card-title fw-bold"><%= trip.name %></h5>
              <h6 class="card-subtitle mb-2 text-muted"><%= trip.destination %></h6>

              <p class="card-text mb-3">
                <%# On utilise l'alias ici %>
                <strong>Voyageurs :</strong> <%= trip.nombre_des_voyageurs || 0 %>
              </p>

              <div class="d-flex gap-2">
                <%= link_to "Détails", trip_path(trip), class: "btn btn-outline-primary btn-sm" %>
                <%= button_to "Supprimer", trip_path(trip), method: :delete, data: { turbo_confirm: "Êtes-vous sûr ?" }, class: "btn btn-outline-danger btn-sm" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center mt-5">
      <p class="text-muted">Vous n'avez pas encore d'envies de voyage.</p>
      <%= link_to "Créer une envie", new_trip_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
