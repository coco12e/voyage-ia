<div class="container mt-5">
  <div class="card shadow-sm border-0 shadow-lg">
    <div class="card-body p-5">
      <h1 class="card-title mb-4 text-dark fw-bold">Détails de votre voyage</h1>
      <hr class="mb-4">

      <div class="row">
        <div class="col-md-6 mb-4">
          <h6 class="text-uppercase text-muted small">Nom du voyage</h6>
          <p class="fs-3 text-primary fw-bold"><%= @trip.name %></p>
        </div>

        <div class="col-md-6 mb-4">
          <h6 class="text-uppercase text-muted small">Destination</h6>
          <p class="fs-3 text-dark"><%= @trip.destination %></p>
        </div>
      </div>

      <div class="row">
        <div class="col-12">
          <h6 class="text-uppercase text-muted small">Nombre de voyageurs</h6>
          <p class="fs-3 text-secondary"><%= @trip.nombre_des_voyageurs %></p>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-5 d-flex gap-3 align-items-center">
    <%= link_to "← Retour à la liste", trips_path, class: "btn btn-outline-primary" %>
    <%= button_to "Supprimer ce voyage", trip_path(@trip), method: :delete, data: { turbo_confirm: "Êtes-vous sûr ?" }, class: "btn btn-outline-danger ms-auto" %>
  </div>
</div>
