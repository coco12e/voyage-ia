<div class="container mt-5">
  <div class="mb-3">
    <%= link_to trips_path, class: "text-primary text-decoration-none fw-bold" do %>
      <i class="fa-solid fa-arrow-left"></i> Retour à la liste
    <% end %>
  </div>

  <div class="row g-4">
    <div class="col-md-8">
      <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-start mb-4">
            <h1 class="h3 fw-bold mb-0">Détails de votre voyage</h1>

            <div class="d-flex gap-3">
              <%= link_to edit_trip_path(@trip), class: "text-secondary text-decoration-none" do %>
                <i class="fa-solid fa-pen-to-square"></i>
              <% end %>

              <%= button_to trip_path(@trip),
                  method: :delete,
                  class: "btn btn-link p-0 text-danger text-decoration-none",
                  data: { confirm: "Supprimer ce voyage ?" } do %>
                <i class="fa-solid fa-trash"></i>
              <% end %>
            </div>
          </div>

          <ul class="list-group list-group-flush">
            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
              <span class="text-dark">Nom du voyage :</span>
              <strong class="text-primary"><%= @trip.name %></strong>
            </li>
            <li class="list-group-item d-flex align-items-center gap-3 px-0 border-top">
              <i class="fa-solid fa-map text-secondary fs-5" style="width: 25px;"></i>
              <strong class="text-dark"><%= @trip.destination %></strong>
            </li>
            <li class="list-group-item d-flex align-items-center gap-3 px-0">
              <i class="fa-solid fa-users text-secondary fs-5" style="width: 25px;"></i>
              <strong class="text-dark"><%= @trip.travellers_number %></strong>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
          <h2 class="h5 fw-bold mb-0">Discussions</h2>
          <%= button_to "Nouveau", trip_chats_path(@trip), class: "btn btn-sm btn-primary rounded-pill px-3" %>
        </div>
        <div class="card-body">
          <% if @chats.any? %>
            <div class="list-group list-group-flush">
              <% @chats.each do |chat| %>
                <%= link_to chat_path(chat), class: "list-group-item list-group-item-action border-0 px-0 d-flex align-items-center gap-2" do %>
                  <i class="fa-regular fa-comment text-primary"></i>
                  <span class="fw-bold"><%= chat.title %></span>
                <% end %>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-3">
              <p class="text-muted small mb-0">Il n'y a pas encore de discussions.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
