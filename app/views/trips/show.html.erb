<div class="container mt-5">
  <div class="row g-4">
    <div class="col-md-8">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h1 class="h3 fw-bold mb-4">Détails de votre voyage</h1>

          <ul class="list-group list-group-flush mb-4">
            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
              <span class="text-dark">Nom du voyage :</span>
              <strong class="text-primary text-end"><%= @trip.name %></strong>
            </li>
            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
              <span class="text-dark">Destination :</span>
              <strong class="text-dark text-end"><%= @trip.destination %></strong>
            </li>
            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
              <span class="text-dark">Nombre de voyageurs :</span>
              <span class="fw-bold text-dark text-end"><%= @trip.travellers_number %></span>
            </li>
          </ul>

          <div class="d-flex flex-wrap align-items-center gap-3">
            <%= link_to "← Retour à la liste", trips_path, class: "btn btn-outline-primary" %>

            <%= link_to "Modifier ce voyage", edit_trip_path(@trip),
                class: "btn text-white fw-bold",
                style: "background-color: #20C997; border: none; padding: 0.5rem 1rem;" %>

            <%= button_to "Supprimer ce voyage", trip_path(@trip),
                method: :delete,
                class: "btn btn-outline-danger" %>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 border-bottom-0">
          <h2 class="h5 fw-bold mb-0">Chats</h2>
        </div>
        <div class="card-body">
          <% if @chats.any? %>
            <div class="list-group list-group-flush mb-3">
              <% @chats.each do |chat| %>
                <%= link_to chat.title, chat_path(chat), class: "list-group-item list-group-item-action border-0 px-0 text-dark fw-bold" %>
              <% end %>
            </div>
          <% else %>
            <p class="text-dark small">Il n'y a pas encore de discussions.</p>
          <% end %>

          <div class="d-grid">
            <%= button_to "Nouvelle discussion", trip_chats_path(@trip), class: "btn btn-primary" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
