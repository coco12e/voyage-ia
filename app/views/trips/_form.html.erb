<%= form_with model: @trip do |f| %>
  <div class="mb-3">
    <%= f.label :name, "Nom du voyage", class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :destination, "Ville de destination", class: "form-label" %>
    <%= f.text_field :destination, class: "form-control" %>
  </div>

  <div class="mb-4">
    <%= f.label :number_of_travelers, "Nombre de voyageurs", class: "form-label" %>
    <%= f.number_field :number_of_travelers, class: "form-control" %>
  </div>

  <div class="d-flex align-items-center gap-3">
    <%= f.submit "Enregistrer", class: "btn btn-primary" %>
    <%= link_to "Annuler", trips_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
