<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <h2>Créer un nouveau voyage</h2>

      <%= simple_form_for(@trip) do |f| %>
        <%= f.input :name, label: "Nom du voyage" %>
        <%= f.input :destination, label: "Ville de destination" %>

        <%# Ce champ doit correspondre à la colonne de votre base de données %>
        <%= f.input :nombre_des_voyageurs, label: "Nombre de voyageurs", as: :integer %>

        <%= f.button :submit, "Créer mon voyage", class: "btn btn-primary" %>
      <% end %>
    </div>
  </div>
</div>
