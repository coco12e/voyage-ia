<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <h2 class="mb-4">Créer un nouveau voyage</h2>

      <%= simple_form_for(@trip) do |f| %>
        <div class="form-inputs">
          <%= f.input :name, label: "Nom du voyage", placeholder: "Ex: Week-end à Tokyo" %>
          <%= f.input :destination, label: "Ville de destination" %>
          <%# On utilise le nom technique réel de la colonne ici %>
          <%= f.input :number_of_travelers, label: "Nombre de voyageurs", as: :integer %>
        </div>

        <div class="form-actions mt-3">
          <%= f.button :submit, "Créer mon voyage", class: "btn btn-primary" %>
          <%= link_to "Annuler", trips_path, class: "btn btn-link" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
