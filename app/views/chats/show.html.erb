<div class="container mt-4 mb-5">
  <div class="d-flex align-items-center mb-4">
    <%= link_to trip_path(@chat.trip), class: "text-decoration-none text-primary me-3" do %>
      ← <%= @chat.trip.name %>
    <% end %>
    <h1 class="h4 fw-bold mb-0"><%= @chat.title %></h1>
  </div>

  <div class="card shadow-sm border mb-4">
    <div class="card-body bg-light p-4" style="min-height: 60vh;">
      <div id="messages">
        <% @chat.messages.each do |message| %>
          <% if message.role == "user" %>
            <div class="d-flex justify-content-end mb-3">
              <div class="bg-primary text-white p-3 rounded" style="max-width: 80%;">
                <div class="small fw-bold mb-1">Vous</div>
                <%= raw(render_markdown(message.content)) %>
              </div>
            </div>
          <% elsif message.role == "assistant" %>
            <div class="d-flex justify-content-start mb-3">
              <div class="bg-white border p-3 rounded" style="max-width: 80%;">
                <div class="small fw-bold text-primary mb-1">Voyage IA</div>
                <%= raw(render_markdown(message.content)) %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="card-footer bg-white p-3">
      <%= simple_form_for [@chat, @message] do |f| %>
        <div class="row g-2">
          <div class="col">
            <%= f.input :content,
                label: false,
                placeholder: "Écrivez votre message...",
                input_html: { class: "form-control" },
                wrapper_html: { class: "mb-0" } %>
          </div>
          <div class="col-auto">
            <%= f.button :submit, 'Envoyer', class: 'btn btn-primary' %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
