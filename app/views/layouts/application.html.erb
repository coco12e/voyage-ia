<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Voyage IA" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom">
      <div class="container">
        <%= link_to "Voyage IA", root_path, class: "navbar-brand fw-bold" %>

        <div class="navbar-nav ms-auto">
          <%= link_to "Accueil", root_path, class: "nav-link #{'active' if current_page?(root_path)}" %>

          <% if user_signed_in? %>
            <%= link_to "Mes voyages", trips_path, class: "nav-link #{'active' if current_page?(trips_path)}" %>
            <%= button_to "Déconnexion", destroy_user_session_path, method: :delete, class: "nav-link btn btn-link" %>
          <% else %>
            <%= link_to "Connexion", new_user_session_path, class: "nav-link" %>
          <% end %>
        </div>
      </div>
    </nav>

    <div class="container mt-3">
      <% flash.each do |type, message| %>
        <% alert_class = type.to_s == 'alert' ? 'danger' : 'info' %>
        <div class="alert alert-<%= alert_class %> alert-dismissible fade show" role="alert">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>
    </div>

    <main class="container mt-4">
      <%= yield %>
    </main>
  </body>
</html>
